// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TodayMatch {
  id             String   @id @default(cuid())
  match_id       String   @unique
  tournament     String
  surface        String
  round          String
  best_of        Int
  match_date     String
  scheduled_time String?
  player1_id     String
  player1_name   String
  player2_id     String
  player2_name   String
  source         String
  odds1          Float?
  odds2          Float?
  odds_source    String?
  fetchedAt      DateTime @default(now())

  @@index([match_date])
}

model Bet {
  id               String     @id @default(cuid())
  matchExternalId  String
  playerExternalId String
  playerName       String
  matchDesc        String
  betType          BetType    @default(MONEYLINE)
  signal           Signal
  modelProb        Float
  impliedProb      Float
  edge             Float
  odds             Float
  closingOdds      Float?
  stake            Float
  toWin            Float?
  status           BetStatus  @default(OPEN)
  result           BetResult?
  pnl              Float?
  clv              Float?
  notes            String?
  placedAt         DateTime   @default(now())
  settledAt        DateTime?
  updatedAt        DateTime   @updatedAt

  @@index([status])
  @@index([placedAt])
  @@index([playerExternalId])
  @@index([matchExternalId])
}

model Bankroll {
  id        String   @id @default(cuid())
  amount    Float
  note      String?
  createdAt DateTime @default(now())
}

model BankrollSnapshot {
  id         String   @id @default(cuid())
  balance    Float
  snapshotAt DateTime @default(now())

  @@index([snapshotAt])
}

enum Signal {
  BET
  LEAN
  PASS
}

enum BetType {
  MONEYLINE
  SPREAD
  TOTAL_OVER
  TOTAL_UNDER
  SET_BETTING
}

enum BetStatus {
  OPEN
  SETTLED
  VOID
  CANCELLED
}

enum BetResult {
  WIN
  LOSS
  PUSH
  HALF_WIN
  HALF_LOSS
}